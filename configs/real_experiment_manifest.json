{
  "name": "llm4unroll_real_experiments",
  "description": "Paper-grade experiment scaffold for native solver runs, larger benchmark subsets, search, ablation, and reporting.",
  "default_timeout_s": 7200,
  "jobs": [
    {
      "job_id": "baseline_pdhg_miplib_train",
      "stage": "baselines",
      "description": "PDHG on MIPLIB root-LP subset with native backends when available",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_baselines",
        "--config",
        "configs/pdhg_miplib_rootlp.yaml",
        "--split",
        "train"
      ],
      "artifacts": [
        "results/tables/pdhg_miplib_rootlp_train.csv"
      ]
    },
    {
      "job_id": "baseline_pdhg_llm_lns_sc_train",
      "stage": "baselines",
      "description": "PDHG on LLM-LNS set-cover LP assets",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_baselines",
        "--config",
        "configs/pdhg_llm_lns_sc.yaml",
        "--split",
        "train"
      ],
      "artifacts": [
        "results/tables/pdhg_llm_lns_sc_train.csv"
      ]
    },
    {
      "job_id": "search_pdhg_miplib_train",
      "stage": "search",
      "description": "LLM-guided search on MIPLIB root-LP subset",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_search",
        "--config",
        "configs/pdhg_miplib_rootlp.yaml",
        "--split",
        "train"
      ],
      "artifacts": [
        "results/tables/search_pdhg_miplib_rootlp_train.csv",
        "results/tables/search_archive_pdhg_miplib_rootlp_train.csv"
      ]
    },
    {
      "job_id": "evolution_no_llm_pdhg_miplib_train",
      "stage": "search_baselines",
      "description": "Evolution without LLM on MIPLIB root-LP subset",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_evolution_baseline",
        "--config",
        "configs/pdhg_miplib_rootlp.yaml",
        "--split",
        "train"
      ],
      "artifacts": [
        "results/tables/evolution_no_llm_pdhg_miplib_rootlp_train.csv"
      ]
    },
    {
      "job_id": "random_search_pdhg_miplib_train",
      "stage": "search_baselines",
      "description": "Random search on MIPLIB root-LP subset",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_random_search",
        "--config",
        "configs/pdhg_miplib_rootlp.yaml",
        "--split",
        "train"
      ],
      "artifacts": [
        "results/tables/random_search_pdhg_miplib_rootlp_train.csv"
      ]
    },
    {
      "job_id": "ood_pdhg_miplib",
      "stage": "generalization",
      "description": "OOD train/validation/test evaluation for MIPLIB-rootLP setting",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.run_ood",
        "--config",
        "configs/pdhg_miplib_rootlp.yaml"
      ],
      "artifacts": [
        "results/tables/ood_pdhg_miplib_rootlp.csv"
      ]
    },
    {
      "job_id": "report_figures",
      "stage": "report",
      "description": "Generate tables, SVG figures, verifier appendix, and native backend report",
      "command": [
        "python3",
        "-m",
        "llm4unroll.experiments.build_report_figures"
      ],
      "artifacts": [
        "results/figures/index.md",
        "results/figures/native_backend_report.html"
      ]
    }
  ]
}
